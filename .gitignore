*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/

# MLflow local store (experiment history; back up via a tracking server)
mlflow.db
mlruns/
mlartifacts/

# Conda / virtualenv
.env
.venv
env/

# Output files (generated, not source)
output/
fg_abundance_table.csv

# Large raw DB downloads — re-download via interaction_analyzer.py
db/*.gz
db/*.txt

# ProLIF 3D-fallback artifacts — regenerate via utils/build_prolif_reference.py
# (need optional heavy deps: ProLIF + MDAnalysis + a docking backend)
db/prolif_pdb/
db/prolif_reference_ifp.json

# Data files — keep test SDF, ignore large user uploads
data/*.mol2
data/*.sdf
!data/test.sdf

# Benchmark downloads — regenerate with run_benchmark.py download
data/benchmark/
output/benchmark/

# Temporary validation/test scripts
tmp_*.py

# STP comparison runner scripts (generated)
tmp_stp_launcher.py

# STP run log (transient)
output/benchmark/stp_run.log
output/benchmark/stp_run_err.log
output/benchmark/stp_pid.txt
output/benchmark/stp_job_id.txt

# Auto-generated PDB batch fetch progress cache
db/fg_residue_map.json

